{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Student Demographics by Region",
  "description": "Converted from Plotly schema 102 - Donut chart",
  "data": {
    "values": [
      { "region": "Urban", "percentage": 40 },
      { "region": "Suburban", "percentage": 35 },
      { "region": "Rural", "percentage": 25 }
    ]
  },
  "mark": { "type": "arc", "innerRadius": 50 },
  "encoding": {
