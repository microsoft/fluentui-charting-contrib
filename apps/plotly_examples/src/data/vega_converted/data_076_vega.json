{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Comparison of Different Demographic Categories Within the Company",
  "description": "Converted from Plotly schema 76 - Horizontal bar chart",
  "data": {
    "values": [
      { "demographic": "Women", "count": 110 },
      { "demographic": "Men", "count": 100 },
      { "demographic": "Nonbinary", "count": 30 }
    ]
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "count",
      "type": "quantitative",
      "axis": { "title": "Employee Count" }
    },
    "y": {
      "field": "demographic",
      "type": "nominal",
      "axis": { "title": "Demographic" }
    }
  }
}
